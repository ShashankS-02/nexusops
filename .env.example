# ============================================================
# NexusOps Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- LLM Provider ---
# Use 'groq' for FREE tier (recommended during development)
# Use 'openai' for better quality (gpt-4o-mini is ~$2-5/month)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# OpenAI (used if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Groq — FREE: sign up at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# --- LangSmith (Agent Tracing) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=nexusops

# --- Tavily (Web Search for Detective Agent) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- PostgreSQL + pgvector ---
DATABASE_URL=postgresql+asyncpg://nexusops:nexusops@localhost:5432/nexusops
DATABASE_URL_SYNC=postgresql://nexusops:nexusops@localhost:5432/nexusops

# --- Redis (Agent State / LangGraph Checkpointing) ---
REDIS_URL=redis://localhost:6379/0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5001

# --- App Settings ---
APP_ENV=development
LOG_LEVEL=INFO
SENTINEL_ANOMALY_THRESHOLD=0.85
HUMAN_APPROVAL_REQUIRED=true
